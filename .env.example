# Auleg Production Environment Configuration
# Copy this file to .env and update values for your deployment

# ─── Core ──────────────────────────────────────────────
# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# CORS origin — your Vercel dashboard domain
CORS_ORIGIN=https://www.auleg.com

# Optional rate limit tuning
# API_RATE_LIMIT_MAX=200
# AUTH_RATE_LIMIT_MAX=20

# ─── Database (PostgreSQL) ────────────────────────────
# Railway adds DATABASE_URL automatically when you provision PostgreSQL
# Or set manually:
DATABASE_URL=postgresql://auleg:password@localhost:5432/auleg

# ─── AI Provider (optional) ───────────────────────────
# Set AI_PROVIDER to "openai" or "anthropic" for LLM-powered analysis
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
#
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Stripe Billing (optional) ────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# ALLOW_INSECURE_BILLING_WEBHOOKS=true  # local development only; never enable in production

# ─── SendGrid Email (optional) ────────────────────────
# SENDGRID_API_KEY=SG....
# EMAIL_FROM=noreply@auleg.com
# EMAIL_FROM_NAME=Auleg

# ─── AI Provider (optional) ───────────────────────────
# Set AI_PROVIDER to "openai" or "anthropic" for LLM-powered analysis
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
#
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Stripe Billing (optional) ────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ─── SendGrid Email (optional) ────────────────────────
# SENDGRID_API_KEY=SG....
# EMAIL_FROM=noreply@auleg.com
# EMAIL_FROM_NAME=Auleg
