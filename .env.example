# Auleg Production Environment Configuration
# Copy this file to .env and update values for your deployment

# ─── Core ──────────────────────────────────────────────
# JWT secret — generate a strong random string (min 32 chars)
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# CORS origin — your dashboard domain
CORS_ORIGIN=https://www.auleg.com

# API URL — used by the dashboard build to connect to the API
API_URL=https://api.auleg.com

# ─── Database ──────────────────────────────────────────
# SQLite (default):
DATABASE_URL=file:./dev.db
# PostgreSQL (upgrade):
# DATABASE_URL=postgresql://auleg:password@localhost:5432/auleg

# ─── AI Provider (optional) ───────────────────────────
# Set AI_PROVIDER to "openai" or "anthropic" for LLM-powered analysis
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
#
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Stripe Billing (optional) ────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ─── SendGrid Email (optional) ────────────────────────
# SENDGRID_API_KEY=SG....
# EMAIL_FROM=noreply@auleg.com
# EMAIL_FROM_NAME=Auleg
