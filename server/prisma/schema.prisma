// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Production: DATABASE_URL=postgresql://user:pass@host:5432/auleg
// Local dev:  DATABASE_URL=file:./dev.db (with provider="sqlite")

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  password            String
  name                String?
  role                String   @default("auditor") // admin, auditor, viewer
  orgId               String?
  org                 Org?     @relation(fields: [orgId], references: [id])
  audits              Audit[]
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique // SHA-256 hash of the token
  userId    String
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Org {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("free") // free, pro, enterprise
  users     User[]
  audits    Audit[]
  billing   BillingAccount?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Audit {
  id               String   @id @default(uuid())
  contractName     String
  contractPath     String
  status           String   @default("pending") // pending, processing, complete, failed
  clausesDetected  Int      @default(0)
  gapsFound        Int      @default(0)
  overallRisk      String?
  riskScore        Float?
  reportJson       String?  // full audit_report.json stored as text
  version          Int      @default(1)
  parentId         String?  // previous version's audit ID
  tags             String   @default("") // comma-separated tags
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  orgId            String?
  org              Org?     @relation(fields: [orgId], references: [id])
  shares           AuditShare[]
  comments         AuditComment[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String   // login, register, audit.create, audit.delete, user.update, org.create, export
  detail    String?
  userId    String?
  userEmail String?
  ip        String?
  createdAt DateTime @default(now())
}

model Webhook {
  id        String   @id @default(uuid())
  url       String
  events    String   // comma-separated: audit.complete,audit.failed
  secretEncrypted String   // AES-256-GCM encrypted HMAC signing secret
  secretIv  String   // Initialization vector for decryption
  secretTag String   // Auth tag for decryption
  active    Boolean  @default(true)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  clauseTypes String   // comma-separated clause types to check
  frameworks  String   // comma-separated frameworks: GDPR,CCPA,SOC2
  userId      String
  orgId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // audit.complete, audit.failed, system, org.invite
  title     String
  message   String
  read      Boolean  @default(false)
  data      String?  // optional JSON payload (e.g. auditId)
  userId    String
  createdAt DateTime @default(now())
}

model ApiKey {
  id        String   @id @default(uuid())
  name      String
  keyHash   String   @unique // SHA-256 hash of the key
  prefix    String   // first 8 chars for display
  scopes    String   @default("audits:read,audits:write") // comma-separated
  lastUsed  DateTime?
  expiresAt DateTime?
  userId    String
  createdAt DateTime @default(now())
}

model AuditShare {
  id        String   @id @default(uuid())
  auditId   String
  audit     Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  sharedWith String  // email of the recipient
  permission String  @default("view") // view, comment
  token     String   @unique // unique share token for link-based access
  expiresAt DateTime?
  createdAt DateTime @default(now())
}

model ScheduledAudit {
  id           String   @id @default(uuid())
  name         String
  contractPath String   // path to stored contract for re-audit
  contractName String
  cron         String   // cron expression (e.g. "0 9 * * 1" = every Monday 9am)
  active       Boolean  @default(true)
  lastRun      DateTime?
  nextRun      DateTime?
  userId       String
  templateId   String?  // optional audit template to apply
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ScoringRule {
  id        String   @id @default(uuid())
  name      String
  clause    String   // clause type this rule applies to
  condition String   // e.g. "missing", "weak", "present"
  weight    Float    @default(1.0) // multiplier for risk score
  action    String   @default("flag") // flag, boost, reduce
  userId    String
  orgId     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditComment {
  id        String   @id @default(uuid())
  auditId   String
  audit     Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  userId    String
  userEmail String
  userName  String?
  clause    String?  // optional: ties comment to a specific clause
  body      String
  parentId  String?  // reply threading
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique
  emailDigest         String   @default("none") // none, daily, weekly
  notifyAuditComplete Boolean  @default(true)
  notifyAuditFailed   Boolean  @default(true)
  notifyShare         Boolean  @default(true)
  defaultTemplateId   String?
  theme               String   @default("dark") // dark, light
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BillingAccount {
  id              String   @id @default(uuid())
  orgId           String   @unique
  org             Org      @relation(fields: [orgId], references: [id])
  stripeCustomerId String?  // Stripe customer ID (null for mock/dev)
  plan            String   @default("free") // free, pro, enterprise
  status          String   @default("active") // active, past_due, canceled, trialing
  trialEndsAt     DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  auditsUsed      Int      @default(0)
  auditsLimit     Int      @default(10) // per month
  usersLimit      Int      @default(3)
  storageUsedMb   Float    @default(0)
  storageLimitMb  Float    @default(100) // MB
  apiCallsUsed    Int      @default(0)
  apiCallsLimit   Int      @default(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BillingEvent {
  id        String   @id @default(uuid())
  orgId     String
  type      String   // plan.upgrade, plan.downgrade, usage.audit, usage.api, payment.success, payment.failed
  detail    String?
  amount    Float?   // in cents
  createdAt DateTime @default(now())
}

model WebhookDelivery {
  id         String   @id @default(uuid())
  webhookId  String
  event      String   // audit.complete, audit.failed, etc.
  payload    String   // JSON payload sent
  status     String   @default("pending") // pending, success, failed
  statusCode Int?
  response   String?  // truncated response body
  attempts   Int      @default(0)
  nextRetry  DateTime?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Legal Knowledge Base ─────────────────────────────

model Regulation {
  id           String   @id @default(uuid())
  code         String   @unique // GDPR, CCPA, LGPD, POPIA, DPDPA, DSA, AIA
  name         String          // General Data Protection Regulation
  jurisdiction String          // EU, US-CA, Brazil, South Africa, India
  effectiveDate DateTime?
  lastAmended  DateTime?
  summary      String          // Brief description
  url          String?         // Official text URL
  articles     RegulationArticle[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RegulationArticle {
  id           String   @id @default(uuid())
  regulationId String
  regulation   Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  articleNum   String          // "28", "32(1)(a)"
  title        String          // "Processor obligations"
  content      String          // Full article text
  summary      String          // Plain-English summary
  relevance    String          // How it relates to DPA auditing
  relatedClauses String @default("") // comma-separated: audit_rights,breach_notification
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EnforcementAction {
  id           String   @id @default(uuid())
  authority    String          // ICO, CNIL, DPC, BfDI, AEPD, Garante
  country      String          // UK, France, Ireland, Germany, Spain, Italy
  date         DateTime
  entity       String          // Company fined
  fineAmount   Float?          // In EUR
  regulation   String          // GDPR, CCPA, etc.
  articles     String          // comma-separated violated articles
  summary      String          // What happened
  impact       String          // How this affects DPA clause analysis
  clauseImpact String @default("") // comma-separated: breach_notification,cross_border_transfer
  sourceUrl    String?
  severity     String   @default("medium") // low, medium, high, critical
  createdAt    DateTime @default(now())
}

model RegulatoryGuidance {
  id           String   @id @default(uuid())
  authority    String          // EDPB, ICO, CNIL, etc.
  title        String
  date         DateTime
  regulation   String
  summary      String
  implications String          // What it means for DPA auditing
  clauseImpact String @default("") // affected clauses
  sourceUrl    String?
  createdAt    DateTime @default(now())
}

model LegalChat {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("New conversation")
  messages  String   // JSON array of {role, content, timestamp}
  context   String?  // JSON: linked auditId, clauseName, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Redlining & Inline Suggestions ──────────────────

model Redline {
  id           String   @id @default(uuid())
  auditId      String
  clause       String   // clause type e.g. "breach_notification"
  originalText String   // exact sentence/paragraph from the DPA
  suggestedText String  // AI-suggested replacement
  explanation  String   // why the change is needed
  severity     String   @default("medium") // low, medium, high, critical
  status       String   @default("pending") // pending, accepted, rejected, modified
  confidence   Float    @default(0.8)
  regulation   String?  // applicable regulation
  article      String?  // specific article reference
  lineStart    Int?     // approximate line in original doc
  lineEnd      Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Multi-File Audit (DPA + Annexes) ─────────────────

model AuditBundle {
  id           String   @id @default(uuid())
  name         String
  status       String   @default("pending") // pending, processing, complete, failed
  primaryAuditId String? // main DPA audit ID
  consolidatedReport String? // merged JSON report
  consolidatedScore  Float?
  consolidatedRisk   String?
  userId       String
  orgId        String?
  files        AuditBundleFile[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditBundleFile {
  id        String   @id @default(uuid())
  bundleId  String
  bundle    AuditBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  auditId   String?  // linked Audit record
  fileName  String
  fileType  String   @default("annex") // primary, annex, schedule, appendix
  filePath  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── Negotiation Workflow ─────────────────────────────

model Negotiation {
  id           String   @id @default(uuid())
  auditId      String
  title        String
  counterparty String   // company name
  status       String   @default("draft") // draft, sent, in_review, countered, accepted, rejected
  currentRound Int      @default(1)
  userId       String
  orgId        String?
  rounds       NegotiationRound[]
  clauses      NegotiationClause[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NegotiationRound {
  id            String   @id @default(uuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  roundNumber   Int
  submittedBy   String   // "us" or "counterparty"
  auditId       String?  // audit of this round's version
  notes         String?
  filePath      String?
  createdAt     DateTime @default(now())
}

model NegotiationClause {
  id            String   @id @default(uuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  clause        String   // clause type
  status        String   @default("open") // open, agreed, disputed, removed
  ourPosition   String?
  theirPosition String?
  agreedText    String?
  notes         String?
  updatedAt     DateTime @updatedAt
}

// ─── Approval Chains ──────────────────────────────────

model ApprovalChain {
  id           String   @id @default(uuid())
  auditId      String
  title        String
  status       String   @default("pending") // pending, in_progress, approved, rejected
  orgId        String?
  steps        ApprovalStep[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ApprovalStep {
  id            String   @id @default(uuid())
  chainId       String
  chain         ApprovalChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  stepOrder     Int
  role          String   // legal_reviewer, dpo, management
  assignedTo    String?  // userId
  assignedEmail String?
  status        String   @default("pending") // pending, approved, rejected, skipped
  comments      String?
  decidedAt     DateTime?
  createdAt     DateTime @default(now())
}

// ─── Counterparty Portal ──────────────────────────────

model CounterpartyLink {
  id           String   @id @default(uuid())
  token        String   @unique
  auditId      String?
  negotiationId String?
  companyName  String
  contactEmail String
  status       String   @default("pending") // pending, submitted, reviewed
  submittedFile String?
  submittedAuditId String?
  expiresAt    DateTime
  userId       String   // who created the link
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Bulk Vendor Assessment ───────────────────────────

model VendorAssessment {
  id           String   @id @default(uuid())
  name         String   // e.g. "Q2 2026 Vendor Review"
  status       String   @default("pending") // pending, processing, complete
  totalVendors Int      @default(0)
  completedVendors Int  @default(0)
  avgRiskScore Float?
  highRiskCount Int     @default(0)
  vendors      VendorEntry[]
  userId       String
  orgId        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VendorEntry {
  id            String   @id @default(uuid())
  assessmentId  String
  assessment    VendorAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  vendorName    String
  auditId       String?  // linked Audit
  status        String   @default("pending") // pending, auditing, complete, failed
  riskScore     Float?
  riskLevel     String?
  fileName      String
  filePath      String
  createdAt     DateTime @default(now())
}

// ─── Custom Regulation Profiles ───────────────────────

model CustomFramework {
  id           String   @id @default(uuid())
  name         String   // e.g. "HIPAA", "PCI-DSS"
  description  String?
  clauses      String   // JSON array of {name, description, weight, required}
  orgId        String?
  userId       String
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Regulatory Change Alerts ─────────────────────────

model RegulatoryAlert {
  id           String   @id @default(uuid())
  type         String   // enforcement, guidance, regulation_change
  title        String
  summary      String
  regulation   String   // GDPR, CCPA, etc. 
  affectedClauses String @default("") // comma-separated
  severity     String   @default("info") // info, warning, critical
  sourceUrl    String?
  read         Boolean  @default(false)
  userId       String
  createdAt    DateTime @default(now())
}

// ─── Integration Configs ──────────────────────────────

model IntegrationConfig {
  id           String   @id @default(uuid())
  provider     String   // slack, teams, ironclad, juro, onetrust, vanta
  type         String   // notification, clm, grc
  config       String   // JSON: {webhookUrl, channel, apiKey, etc.}
  active       Boolean  @default(true)
  userId       String
  orgId        String?
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── SSO/SAML/OIDC Configs ────────────────────────────

model SSOConfig {
  id           String   @id @default(uuid())
  orgId        String   @unique
  provider     String   // saml, oidc
  enabled      Boolean  @default(true)
  // SAML fields
  entryPoint   String?  // IdP SSO URL
  issuer       String?  // SP entity ID
  cert         String?  // X.509 cert for signature validation
  // OIDC fields
  clientId     String?
  clientSecret String?
  discoveryUrl String?  // .well-known/openid-configuration URL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Data Residency ──────────────────────────────────

model DataResidencyConfig {
  id           String   @id @default(uuid())
  orgId        String   @unique
  region       String   // eu, us, ap, custom
  storageZone  String?  // specific zone (eu-west-1, us-east-1, etc.)
  encryptionKey String? // org-specific encryption key identifier
  retentionDays Int     @default(365) // data retention period
  deletionPolicy String @default("soft") // soft, hard
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Terms of Service / DPA Acceptance ────────────────

model TermsAcceptance {
  id           String   @id @default(uuid())
  userId       String
  documentType String   // tos, dpa, privacy_policy
  documentVersion String // e.g. "2.1"
  acceptedAt   DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
}

model LegalDocument {
  id           String   @id @default(uuid())
  type         String   // tos, dpa, privacy_policy
  version      String   // e.g. "2.1"
  title        String
  content      String   // full text / markdown
  effectiveDate DateTime
  supersedes   String?  // previous version ID
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([type, version])
}

// ─── Clause Benchmarks ───────────────────────────────

model ClauseBenchmark {
  id           String   @id @default(uuid())
  clause       String   // clause type
  avgScore     Float
  medianScore  Float
  p25Score     Float    // 25th percentile
  p75Score     Float    // 75th percentile
  sampleSize   Int
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

// ─── Compliance Certificates ──────────────────────────

model ComplianceCertificate {
  id           String   @id @default(uuid())
  auditId      String
  certificateNumber String @unique
  issuedTo     String   // company name
  issuedBy     String   // auditor name
  overallScore Float
  frameworks   String   // comma-separated: GDPR,CCPA
  validFrom    DateTime
  validUntil   DateTime
  status       String   @default("active") // active, revoked, expired
  pdfPath      String?
  userId       String
  createdAt    DateTime @default(now())
}

// ─── Audit Evidence Trail ─────────────────────────────

model AuditEvidence {
  id           String   @id @default(uuid())
  auditId      String
  action       String   // created, reviewed, redline_accepted, approved, certificate_issued
  actor        String   // userId or email
  actorName    String?
  detail       String?  // description of what happened
  metadata     String?  // JSON: {clause, oldScore, newScore, etc.}
  createdAt    DateTime @default(now())
}
